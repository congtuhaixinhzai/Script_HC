{
  "basic": [
    {"id": "temp_user", "name": "Temp người dùng (%TEMP%)", "type": "path", "path": "%TEMP%", "risk": "safe", "default_selected": true},
    {"id": "temp_sys", "name": "Temp hệ thống (Windows\\Temp)", "type": "path", "path": "%SystemRoot%\\Temp", "risk": "safe", "default_selected": true},
    {"id": "recycle", "name": "Thùng rác", "type": "cmd", "cmd": "rd /s /q %systemdrive%\\$Recycle.Bin", "risk": "safe", "default_selected": true, "always_show": true},
    {"id": "dns", "name": "Xóa cache DNS", "type": "cmd", "cmd": "ipconfig /flushdns", "risk": "safe", "default_selected": false, "always_show": true},
    {"id": "recent", "name": "Recent Items (lịch sử mở file)", "type": "path", "path": "%APPDATA%\\Microsoft\\Windows\\Recent", "risk": "safe", "default_selected": true}
  ],
